NODE_ENV=development
APP_NAME=OrnaCore API
APP_HOST=0.0.0.0
APP_PORT=4000
APP_BASE_URL=http://localhost:4000
ADMIN_APP_URL=http://localhost:5173
APP_TIMEZONE=Asia/Kolkata
APP_CURRENCY=INR
API_PREFIX=/api/v1
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=3306
DB_NAME=ornacore
DB_TEST_NAME=ornacore_test
DB_USER=ornacore
DB_PASSWORD=change_me
DB_TIMEZONE=+00:00
DB_LOGGING=false
DB_POOL_MIN=0
DB_POOL_MAX=10

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace_with_at_least_32_characters
JWT_REFRESH_SECRET=replace_with_a_different_32_character_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=ornacore-backend
JWT_AUDIENCE=ornacore-clients

BCRYPT_ROUNDS=12
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5

SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=false

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_PASS=
SMTP_FROM="OrnaCore Admin Toolbox <no-reply@example.com>"
SMTP_CONNECTION_TIMEOUT_MS=10000
MAIL_FROM_NAME=OrnaCore
MAIL_FROM_ADDRESS=no-reply@example.com

MEDIA_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_ROOT_FOLDER=ornacore/dev
LOCAL_UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE_MB=10

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
